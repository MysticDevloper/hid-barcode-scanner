<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background"
    android:gravity="center">

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_camera"
        android:contentDescription="@string/scanner" />

    <TextView
        android:id="@+id/widget_last_scan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/widget_last_scan"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_connection_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:text="@string/widget_not_connected"
        android:textSize="12sp"
        android:textColor="#AAAAAA" />

    <TextView
        android:id="@+id/widget_tap_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/widget_tap_to_scan"
        android:textSize="11sp"
        android:textColor="#888888" />

</LinearLayout>
